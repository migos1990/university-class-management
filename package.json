{
  "name": "university-class-management",
  "version": "1.0.0",
  "description": "Educational application security demonstration platform for university students",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/classroom-manager.js",
    "setup": "node scripts/setup.js",
    "stop": "node scripts/classroom-stop.js",
    "test": "node scripts/smoke-test.js",
    "test:open": "node scripts/smoke-test.js --open",
    "test:integration": "node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "keywords": [
    "education",
    "security",
    "authentication",
    "authorization",
    "encryption"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "qrcode": "^1.5.3",
    "selfsigned": "^2.4.1",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
