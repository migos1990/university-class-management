<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : t('nav.defaultTitle') %></title>
  <link rel="stylesheet" href="/styles.css">
<% if (locals.needsPrism) { %>
<link rel="stylesheet" href="/vendor/prism/prism-one-dark.css">
<link rel="stylesheet" href="/vendor/prism/prism-line-numbers.css">
<link rel="stylesheet" href="/vendor/prism/prism-line-highlight.css">
<style>
  .line-highlight {
    background: rgba(224, 108, 117, 0.15) !important;
    border-left: 3px solid #e06c75;
  }
</style>
<% } %>
</head>
<body>
  <%# Instructor broadcast banner — polls /api/instructor-message every 30s %>
  <div id="instructor-banner" style="display:none;position:sticky;top:0;z-index:9999;background:#002855;color:#fff;padding:0.6rem 1.5rem;font-size:0.9rem;display:none;align-items:center;justify-content:space-between;gap:1rem;">
    <span id="instructor-banner-text"></span>
    <button onclick="document.getElementById('instructor-banner').style.display='none'" style="background:transparent;border:1px solid rgba(255,255,255,0.5);color:#fff;border-radius:3px;padding:2px 10px;cursor:pointer;font-size:0.8rem;flex-shrink:0;"><%= t('common.close') %></button>
  </div>
  <script>
    (function() {
      let _dismissed = null;
      function checkBroadcast() {
        fetch('/api/instructor-message')
          .then(r => r.json())
          .then(d => {
            const banner = document.getElementById('instructor-banner');
            const text   = document.getElementById('instructor-banner-text');
            if (d.message && d.message !== _dismissed) {
              text.textContent = '\u{1F4E2} ' + d.message;
              banner.style.display = 'flex';
            } else if (!d.message) {
              banner.style.display = 'none';
            }
          })
          .catch(() => {});
      }
      document.getElementById('instructor-banner').querySelector('button').addEventListener('click', function() {
        const text = document.getElementById('instructor-banner-text').textContent;
        _dismissed = text.replace('\u{1F4E2} ', '');
      });
      checkBroadcast();
      setInterval(checkBroadcast, 30000);
    })();
  </script>
  <% if (typeof user !== 'undefined' && user) { %>
  <div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href="/dashboard" class="sidebar-logo">
          <img src="/images/hec-logo.svg" alt="HEC Montréal">
          <div>
            <div class="sidebar-logo-text">HEC Montréal</div>
            <div class="sidebar-logo-subtitle"><%= t('nav.appSubtitle') %></div>
          </div>
        </a>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section">
          <div class="nav-section-title"><%= t('nav.main') %></div>
          <a href="/dashboard" class="nav-link">
            <span class="nav-icon">📊</span>
            <span><%= t('common.dashboard') %></span>
          </a>
          <a href="/classes" class="nav-link">
            <span class="nav-icon">📚</span>
            <span><%= t('nav.classes') %></span>
          </a>
        </div>

        <% if (user.role === 'admin') { %>
        <div class="nav-section">
          <div class="nav-section-title"><%= t('nav.administration') %></div>
          <a href="/admin/security" class="nav-link">
            <span class="nav-icon">🔒</span>
            <span><%= t('nav.securityPanel') %></span>
          </a>
          <a href="/admin/audit-logs" class="nav-link">
            <span class="nav-icon">📋</span>
            <span><%= t('nav.auditLogs') %></span>
          </a>
          <a href="/admin/mfa-setup" class="nav-link">
            <span class="nav-icon">🔐</span>
            <span><%= t('nav.mfaSetup') %></span>
          </a>
          <a href="/admin/backups" class="nav-link">
            <span class="nav-icon">💾</span>
            <span><%= t('nav.backups') %></span>
          </a>
        </div>
        <% } %>

        <% if (user.role === 'professor') { %>
        <div class="nav-section">
          <div class="nav-section-title"><%= t('nav.teaching') %></div>
          <a href="/dashboard" class="nav-link">
            <span class="nav-icon">📝</span>
            <span><%= t('nav.myClasses') %></span>
          </a>
        </div>
        <% } %>

        <% if (user.role === 'student') { %>
        <div class="nav-section">
          <div class="nav-section-title"><%= t('nav.learning') %></div>
          <a href="/dashboard" class="nav-link">
            <span class="nav-icon">📖</span>
            <span><%= t('nav.myEnrollments') %></span>
          </a>
        </div>
        <% } %>

        <div class="nav-section">
          <div class="nav-section-title"><%= t('nav.securityLabs') %></div>
          <a href="/sca" class="nav-link <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/sca') ? 'active' : '' %>">
            <span class="nav-icon">🔍</span>
            <span><%= t('nav.staticAnalysis') %></span>
          </a>
          <a href="/dast" class="nav-link <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/dast') ? 'active' : '' %>">
            <span class="nav-icon">⚡</span>
            <span><%= t('nav.dynamicAnalysis') %></span>
          </a>
          <a href="/vm" class="nav-link <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/vm') ? 'active' : '' %>">
            <span class="nav-icon">📊</span>
            <span><%= t('nav.vulnManagement') %></span>
          </a>
          <a href="/pentest" class="nav-link <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/pentest') ? 'active' : '' %>">
            <span class="nav-icon">🎯</span>
            <span><%= t('nav.pentestLab') %></span>
          </a>
        </div>
      </nav>

      <div class="sidebar-footer">
        <div class="user-profile">
          <div class="user-avatar">👤</div>
          <div class="user-details">
            <div class="user-name"><%= user.username %></div>
            <div class="user-role"><%= ({admin: t('nav.roleAdmin'), professor: t('nav.roleProf'), student: t('nav.roleStudent')})[user.role] || user.role %></div>
          </div>
        </div>
        <a href="/auth/logout" class="logout-btn"><%= t('common.logout') %></a>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
      <div class="security-status">
        <div class="security-badges">
          <span class="security-label"><%= t('nav.securityStatus') %></span>
          <span class="badge <%= securitySettings.mfa_enabled ? 'badge-success' : 'badge-danger' %>">
            <%= t('security.badges.mfa') %>: <%= securitySettings.mfa_enabled ? t('security.status.on') : t('security.status.off') %>
          </span>
          <span class="badge <%= securitySettings.rbac_enabled ? 'badge-success' : 'badge-danger' %>">
            <%= t('security.badges.rbac') %>: <%= securitySettings.rbac_enabled ? t('security.status.on') : t('security.status.off') %>
          </span>
          <span class="badge <%= securitySettings.encryption_at_rest ? 'badge-success' : 'badge-danger' %>">
            <%= t('security.badges.passwords') %>: <%= securitySettings.encryption_at_rest ? t('security.badges.encrypted') : t('security.badges.plaintext') %>
          </span>
          <span class="badge <%= securitySettings.field_encryption ? 'badge-success' : 'badge-danger' %>">
            <%= t('security.badges.data') %>: <%= securitySettings.field_encryption ? t('security.badges.encrypted') : t('security.badges.plaintext') %>
          </span>
          <span class="badge <%= securitySettings.https_enabled ? 'badge-success' : 'badge-danger' %>">
            <%= securitySettings.https_enabled ? 'HTTPS' : 'HTTP' %>
          </span>
          <span class="badge <%= securitySettings.audit_logging ? 'badge-success' : 'badge-danger' %>">
            <%= t('security.badges.logging') %>: <%= securitySettings.audit_logging ? t('security.status.on') : t('security.status.off') %>
          </span>
          <span class="badge <%= securitySettings.rate_limiting ? 'badge-success' : 'badge-danger' %>">
            <%= t('security.badges.rateLimit') %>: <%= securitySettings.rate_limiting ? t('security.status.on') : t('security.status.off') %>
          </span>
        </div>
      </div>

      <div class="page-content">
  <% } else { %>
  <div class="page-content" style="padding: 2rem;">
  <% } %>
