<%- include('../partials/header') %>

<div class="page-header">
  <h1 class="page-title"><%= title %></h1>
  <p class="page-subtitle"><%= subtitle %></p>
  <a href="/sca" style="display:inline-block; background:#e9ecef; color:#002855; padding:6px 14px; border-radius:4px; font-size:0.85rem; text-decoration:none; margin-top:0.5rem;">
    &larr; <%= t('sca.answerKey.backToInstructor') %>
  </a>
</div>

<% findings.forEach(function(f) {
  var isConfirmed = f.expectedClassification.indexOf('investigation') === -1
    && f.expectedClassification.indexOf('Investigation') === -1;
  var clsBadgeClass = isConfirmed ? 'cls-confirmed' : 'cls-needs';
%>
<div class="ak-card">
  <div class="ak-card-header">
    <span class="ak-finding-num"><%= f.id %></span>
    <div>
      <div class="ak-finding-title"><%= f.title %></div>
      <div class="ak-file-path"><%= f.file_path %>:<%= f.line_number %></div>
    </div>
    <span class="badge-sm sev-<%= f.severity %>" style="margin-left:auto;"><%= f.severity %></span>
  </div>

  <div style="margin-bottom:1rem;">
    <div class="ak-section-label"><%= labels.expectedClassification %></div>
    <span class="badge-sm <%= clsBadgeClass %>" style="font-size:0.85rem; padding:4px 12px;"><%= f.expectedClassification %></span>
  </div>

  <div style="margin-bottom:1rem;">
    <div class="ak-section-label"><%= labels.reasoning %></div>
    <div class="ak-reasoning"><%= f.reasoning %></div>
  </div>

  <div>
    <div class="ak-section-label"><%= labels.discussionPrompt %></div>
    <div class="ak-discussion"><%= f.discussion %></div>
  </div>
</div>
<% }) %>

<%- include('../partials/footer') %>
