<%- include('../partials/header') %>

<div class="page-header">
  <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
    <% if (prevId) { %>
      <a href="/sca/findings/<%= prevId %>" style="color:#002855; text-decoration:none; font-size:1.5rem; font-weight:bold;" title="<%= t('common.previous') %>">&larr;</a>
    <% } else { %>
      <span style="color:#ccc; font-size:1.5rem; font-weight:bold;">&larr;</span>
    <% } %>
    <a href="/sca" style="color:#666; text-decoration:none; font-size:0.9rem;"><%= t('sca.findingDetail.backToLab') %></a>
    <h1 class="page-title" style="margin:0; flex:1;"><%= finding.title %></h1>
    <% if (nextId) { %>
      <a href="/sca/findings/<%= nextId %>" style="color:#002855; text-decoration:none; font-size:1.5rem; font-weight:bold;" title="<%= t('common.next') %>">&rarr;</a>
    <% } else { %>
      <span style="color:#ccc; font-size:1.5rem; font-weight:bold;">&rarr;</span>
    <% } %>
  </div>
</div>

<style>
  .sev-Critical  { background:#ffe0e0; color:#c0392b; }
  .sev-High      { background:#fff0e0; color:#c0732a; }
  .sev-Medium    { background:#fffbe0; color:#9a7d0a; }
  .sev-Low       { background:#e8f8e8; color:#1e8449; }
  .badge-sm { display:inline-block; padding:2px 10px; border-radius:4px; font-size:0.8rem; font-weight:600; }
  .cls-confirmed      { background:#d4edda; color:#155724; }
  .cls-false_positive { background:#f8d7da; color:#721c24; }
  .cls-needs          { background:#fff3cd; color:#856404; }
</style>

<%
  const diffColors = {
    easy: { bg: '#e8f8e8', color: '#1e8449' },
    medium: { bg: '#fff0e0', color: '#c0732a' },
    advanced: { bg: '#ffe0e0', color: '#c0392b' }
  };
  const diffLabel = {
    easy: t('sca.difficulty.easy'),
    medium: t('sca.difficulty.medium'),
    advanced: t('sca.difficulty.advanced')
  };
%>

<div style="display:grid; grid-template-columns:2fr 1fr; gap:1.5rem; align-items:start;">

  <!-- Left column: finding info -->
  <div>
    <div class="card" style="margin-bottom:1rem;">
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem;">
        <span class="badge-sm sev-<%= finding.severity %>"><%= finding.severity %></span>
        <span class="badge-sm" style="background:#e8f0ff;color:#1a5276;"><%= finding.cwe %></span>
        <span class="badge-sm" style="background:#f0f0f0;color:#333;"><%= finding.category %></span>
        <span class="badge-sm" style="background:#f0f0f0;color:#333;"><%= t('sca.findingDetail.tool') %> : <%= finding.tool %></span>
        <span class="badge-sm" style="background:<%= diffColors[finding.difficulty].bg %>; color:<%= diffColors[finding.difficulty].color %>;"><%= diffLabel[finding.difficulty] %></span>
      </div>

      <h3 style="margin-bottom:0.5rem;"><%= t('sca.findingDetail.location') %></h3>
      <p style="font-family:monospace; background:#f8f9fa; padding:0.5rem; border-radius:4px; margin-bottom:1rem;">
        <%= finding.file_path %>:<%= finding.line_number %>
      </p>

      <h3 style="margin-bottom:0.5rem;"><%= t('sca.findingDetail.codeSnippet') %></h3>
      <pre class="line-numbers" data-start="<%= finding.snippet_start_line %>" data-line="<%= finding.line_number %>" data-line-offset="<%= finding.snippet_start_line - 1 %>" style="border-radius:6px; margin-bottom:1rem;"><code class="language-<%= finding.id === 11 ? 'json' : 'javascript' %>"><%= finding.code_snippet %></code></pre>

      <h3 style="margin-bottom:0.5rem;"><%= t('sca.findingDetail.description') %></h3>
      <p style="margin-bottom:1rem; line-height:1.7;"><%= finding.description %></p>

      <% if (user.role === 'student') { %>
      <div style="margin-bottom:1rem;">
        <button onclick="toggleHints()" type="button" style="background:none; border:1px solid #dee2e6; border-radius:4px; padding:6px 14px; cursor:pointer; color:#666; font-size:0.9rem;">
          Besoin d'aide ?
        </button>
        <div id="hints-section" style="display:none; margin-top:0.75rem; padding:0.75rem; background:#f8f9fa; border-radius:6px; border-left:3px solid #002855;">
          <strong style="color:#002855; font-size:0.9rem;">Pistes d'analyse</strong>
          <ul style="margin:0.5rem 0 0; padding-left:1.25rem; font-size:0.9rem; line-height:1.8; color:#333;">
            <li><%= t('sca.findings.' + finding.id + '.hint1') %></li>
            <li><%= t('sca.findings.' + finding.id + '.hint2') %></li>
            <% if (t('sca.findings.' + finding.id + '.hint3') !== 'sca.findings.' + finding.id + '.hint3') { %>
              <li><%= t('sca.findings.' + finding.id + '.hint3') %></li>
            <% } %>
          </ul>
        </div>
      </div>
      <% } %>

      <h3 style="margin-bottom:0.5rem;"><%= t('sca.findingDetail.remediationGuidance') %></h3>
      <p style="line-height:1.7;"><%= finding.remediation %></p>
    </div>

    <%# AKEY-05: Inline answer -- NOT rendered for students (absent from page source) %>
    <% if (user.role !== 'student' && answerKey) { %>
    <div class="card" style="margin-bottom:1rem; border-left:4px solid #002855;">
      <details>
        <summary style="cursor:pointer; font-weight:600; color:#002855; padding:0.5rem 0;">
          <%= t('sca.answerKey.inlineTitle') %>
        </summary>
        <div style="margin-top:0.75rem;">
          <p style="margin-bottom:0.5rem;">
            <strong><%= t('sca.answerKey.expectedClassification') %> :</strong>
            <span class="badge-sm <%= answerKey.classification.includes('investigation') ? 'cls-needs' : 'cls-confirmed' %>">
              <%= answerKey.classification %>
            </span>
          </p>
          <p style="margin-bottom:0.5rem; line-height:1.7;">
            <strong><%= t('sca.answerKey.reasoning') %> :</strong>
            <%= answerKey.reasoning %>
          </p>
          <p style="line-height:1.7;">
            <strong><%= t('sca.answerKey.discussionPrompt') %> :</strong>
            <em><%= answerKey.discussion %></em>
          </p>
        </div>
      </details>
    </div>
    <% } %>

    <% if (user.role !== 'student' && allReviews.length > 0) { %>
    <div class="card">
      <h3 style="margin-bottom:1rem;"><%= t('sca.findingDetail.studentReviews') %> (<%= allReviews.length %>)</h3>
      <% allReviews.forEach(r => {
        const student = users ? users.find(u => u.id == r.student_id) : null;
      %>
      <div style="border:1px solid #dee2e6; border-radius:6px; padding:0.75rem; margin-bottom:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
          <strong><%= t('sca.instructor.student') %> #<%= r.student_id %></strong>
          <span class="badge-sm cls-<%= r.classification === 'needs_investigation' ? 'needs' : r.classification %>">
            <%= r.classification.replace('_',' ') %>
          </span>
        </div>
        <% if (r.student_notes) { %><p style="font-size:0.9rem; color:#444; margin-bottom:0.5rem;"><strong><%= t('sca.studentDetail.notes') %> :</strong> <%= r.student_notes %></p><% } %>
        <% if (r.remediation_notes) { %><p style="font-size:0.9rem; color:#444;"><strong><%= t('sca.findingDetail.proposedRemediation') %> :</strong> <%= r.remediation_notes %></p><% } %>
        <div style="font-size:0.75rem; color:#999; margin-top:0.5rem;">
          <%= t('sca.instructor.status') %> : <%= r.status === 'submitted' ? t('sca.studentLab.submitted') : r.status %><% if (r.submitted_at) { %> · <%= t('sca.findingDetail.submittedOn') %> <%= new Date(r.submitted_at).toLocaleString() %><% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Right column: student review form or VM status -->
  <div>
    <% if (user.role === 'student') { %>
    <div class="card">
      <h3 style="margin-bottom:1rem;"><%= t('sca.findingDetail.yourReview') %></h3>
      <% if (myReview && myReview.status === 'submitted') { %>
        <div style="background:#d4edda; border-radius:6px; padding:0.75rem; margin-bottom:1rem; color:#155724;">
          <%= t('sca.findingDetail.submittedOn') %> <%= new Date(myReview.submitted_at).toLocaleString() %>
        </div>
      <% } %>
      <form method="POST" action="/sca/findings/<%= finding.id %>/review">
        <div style="margin-bottom:0.75rem;">
          <label style="display:block; font-weight:600; margin-bottom:0.4rem;"><%= t('sca.findingDetail.classification') %></label>
          <select name="classification" required style="width:100%; padding:8px; border:1px solid #ced4da; border-radius:4px;">
            <option value=""><%= t('sca.findingDetail.selectOption') %></option>
            <option value="confirmed"           <%= myReview && myReview.classification==='confirmed'           ? 'selected':'' %>><%= t('sca.common.truePositive') %></option>
            <option value="false_positive"      <%= myReview && myReview.classification==='false_positive'      ? 'selected':'' %>><%= t('sca.common.falsePositive') %></option>
            <option value="needs_investigation" <%= myReview && myReview.classification==='needs_investigation' ? 'selected':'' %>><%= t('sca.common.needsInvestigation') %></option>
          </select>
        </div>
        <div style="margin-bottom:0.75rem;">
          <label style="display:block; font-weight:600; margin-bottom:0.4rem;"><%= t('sca.findingDetail.yourNotes') %></label>
          <textarea name="student_notes" rows="4" style="width:100%; padding:8px; border:1px solid #ced4da; border-radius:4px; font-size:0.9rem;"><%= myReview ? (myReview.student_notes || '') : '' %></textarea>
        </div>
        <div style="margin-bottom:1rem;">
          <label style="display:block; font-weight:600; margin-bottom:0.4rem;"><%= t('sca.findingDetail.proposedRemediation') %></label>
          <textarea name="remediation_notes" rows="4" style="width:100%; padding:8px; border:1px solid #ced4da; border-radius:4px; font-size:0.9rem;"><%= myReview ? (myReview.remediation_notes || '') : '' %></textarea>
        </div>
        <div style="display:flex; gap:0.5rem;">
          <button type="submit" name="action" value="save" style="background:#6c757d; color:#fff; border:none; border-radius:4px; padding:8px 14px; cursor:pointer;"><%= t('sca.findingDetail.saveDraft') %></button>
          <button type="submit" name="action" value="submit" style="background:#002855; color:#fff; border:none; border-radius:4px; padding:8px 14px; cursor:pointer;"><%= t('sca.findingDetail.submit') %></button>
        </div>
      </form>
    </div>
    <% } %>

    <% if (user.role !== 'student') { %>
    <div class="card">
      <h3 style="margin-bottom:1rem;"><%= t('sca.findingDetail.vulnerabilityManager') %></h3>
      <% if (vmEntry) { %>
        <div style="background:#d4edda; border-radius:6px; padding:0.75rem; color:#155724; margin-bottom:1rem;">
          <%= t('sca.findingDetail.importedToVM') %> <a href="/vm/vulns/<%= vmEntry.id %>" style="color:#155724; font-weight:600;">#<%= vmEntry.id %></a>
        </div>
      <% } else { %>
        <p style="font-size:0.9rem; color:#666; margin-bottom:1rem;"><%= t('sca.findingDetail.notImported') %></p>
        <button onclick="importFinding()" style="background:#002855; color:#fff; border:none; border-radius:4px; padding:8px 16px; cursor:pointer;"><%= t('sca.findingDetail.pushToVM') %></button>
      <% } %>
    </div>
    <% } %>

    <div class="card" style="margin-top:0;">
      <h3 style="margin-bottom:0.5rem;"><%= t('sca.findingDetail.references') %></h3>
      <ul style="padding-left:1.25rem; font-size:0.9rem; line-height:2;">
        <li><a href="https://cwe.mitre.org/data/definitions/<%= finding.cwe.replace('CWE-','') %>.html" target="_blank"><%= finding.cwe %> — MITRE CWE</a></li>
        <li><a href="https://owasp.org/www-project-top-ten/" target="_blank">OWASP Top 10</a></li>
      </ul>
    </div>
  </div>
</div>

<% if (user.role !== 'student') { %>
<script>
async function importFinding() {
  if (!confirm('<%= t("sca.findingDetail.pushToVM") %>: "<%= finding.title %>"?')) return;
  try {
    const res = await fetch('/sca/import-to-vm/<%= finding.id %>', { method:'POST' });
    const data = await res.json();
    if (data.success) {
      alert('<%= t("sca.findingDetail.importedToVM") %>');
      location.reload();
    } else {
      alert(data.error || '<%= t("sca.common.errorSaving") %>');
    }
  } catch(e) { alert('<%= t("sca.common.networkError") %>'); }
}
</script>
<% } %>

<% if (user.role === 'student') { %>
<script>
function toggleHints() {
  var el = document.getElementById('hints-section');
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>
<% } %>

<%- include('../partials/footer') %>
