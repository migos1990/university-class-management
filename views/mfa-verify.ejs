<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof t === 'function' ? t('mfa.verifyTitle') : 'Vérification MFA' %> - HEC Montréal</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: #002855;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }

    .mfa-container {
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      padding: 3rem;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }

    .mfa-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 1.5rem;
    }

    .mfa-logo img {
      width: 36px;
      height: 36px;
      border-radius: 6px;
    }

    .mfa-logo-text {
      font-size: 1rem;
      font-weight: 600;
      color: #002855;
    }

    h1 {
      color: #002855;
      margin-bottom: 0.5rem;
      font-size: 1.5rem;
    }

    .subtitle {
      color: #666;
      margin-bottom: 2rem;
      font-size: 0.95rem;
    }

    .alert-danger {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
      padding: 1rem;
      border-radius: 6px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    label {
      display: block;
      margin-bottom: 0.5rem;
      color: #333;
      font-weight: 500;
      font-size: 0.9rem;
    }

    input {
      width: 100%;
      padding: 0.75rem;
      border: 2px solid #dee2e6;
      border-radius: 6px;
      font-size: 1.5rem;
      text-align: center;
      letter-spacing: 0.5rem;
      font-family: monospace;
      transition: border-color 0.2s;
    }

    input:focus {
      outline: none;
      border-color: #002855;
    }

    .btn {
      width: 100%;
      padding: 0.875rem;
      background: #002855;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }

    .btn:hover {
      background: #001a3d;
    }

    .help-text {
      margin-top: 1.5rem;
      color: #666;
      font-size: 0.85rem;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <div class="mfa-container">
    <div class="mfa-logo">
      <img src="/images/hec-logo.svg" alt="HEC Montréal">
      <span class="mfa-logo-text">HEC Montréal</span>
    </div>

    <h1><%= typeof t === 'function' ? t('mfa.verifyTitle') : 'Vérification en deux étapes' %></h1>
    <p class="subtitle"><%= typeof t === 'function' ? t('mfa.verifySubtitle') : 'Entrez le code à 6 chiffres de votre application d\'authentification' %></p>

    <% if (error) { %>
      <div class="alert-danger">
        <%= error %>
      </div>
    <% } %>

    <form action="/auth/mfa-verify" method="POST">
      <div class="form-group">
        <label for="code"><%= typeof t === 'function' ? t('mfa.verifyLabel') : 'Code de vérification' %></label>
        <input type="text" id="code" name="code" pattern="[0-9]{6}" maxlength="6" required autofocus autocomplete="one-time-code" inputmode="numeric" aria-label="Code de vérification à 6 chiffres">
      </div>

      <button type="submit" class="btn"><%= typeof t === 'function' ? t('mfa.verifyButton') : 'Vérifier' %></button>
    </form>

    <p class="help-text">
      <%= typeof t === 'function' ? t('mfa.verifyHelp') : 'Ouvrez Google Authenticator sur votre appareil mobile et entrez le code à 6 chiffres affiché pour ce compte.' %>
    </p>
  </div>
</body>
</html>
